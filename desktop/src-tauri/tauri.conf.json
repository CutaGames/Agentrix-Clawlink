{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Agentrix Desktop",
  "version": "0.1.0",
  "identifier": "top.agentrix.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' https://api.agentrix.top https://agentrix.top; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://api.agentrix.top https://agentrix.top https://*.agentrix.top; connect-src 'self' http://ipc.localhost https://api.agentrix.top https://agentrix.top wss://api.agentrix.top; font-src 'self' data:; media-src 'self' blob:"
    },
    "windows": [
      {
        "label": "main",
        "title": "Agentrix",
        "width": 400,
        "height": 400,
        "url": "index.html",
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese"],
        "installerIcon": "icons/icon.ico",
        "installMode": "both"
      }
    },
    "macOS": {
      "signingIdentity": null,
      "entitlements": null,
      "providerShortName": null,
      "minimumSystemVersion": "10.15"
    },
    "publisher": "CutaGames",
    "copyright": "© 2025 CutaGames. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "AI Agent Desktop Assistant",
    "longDescription": "Agentrix Desktop — Your AI-powered productivity assistant with floating ball, multi-tab chat, workspace integration, and cross-device sync."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.agentrix.top/api/desktop/update/{{target}}/{{arch}}/{{current_version}}",
        "https://staging-api.agentrix.top/api/desktop/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "RWTg+R2wzh3NbTwmHgiB/g4+cL0C76DKvu1RnLccTxVFq/A+EQpFO3jX"
    }
  }
}
