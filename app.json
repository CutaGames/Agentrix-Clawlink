{
  "expo": {
    "name": "Agentrix",
    "slug": "agentrix-mobile",
    "scheme": "agentrix",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./frontend/public/brand/agentrix-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./Agentrix Logo/agentrix_logo_square_transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.agentrix.claw",
      "infoPlist": {
        "CFBundleDisplayName": "Agentrix",
        "LSApplicationQueriesSchemes": [
          "metamask",
          "okx",
          "okex",
          "trust",
          "rainbow",
          "twitter",
          "twitterauth",
          "discord",
          "tg",
          "telegram",
          "imtokenv2",
          "tpoutside",
          "bitkeep",
          "ledgerlive",
          "bnc"
        ],
        "NSCameraUsageDescription": "Agentrix Claw uses the camera to scan QR codes for binding your OpenClaw instance.",
        "NSBluetoothAlwaysUsageDescription": "Agentrix uses Bluetooth to scan and connect to nearby wearable devices.",
        "NSMicrophoneUsageDescription": "Agentrix Claw uses the microphone for voice commands to your AI agent.",
        "NSPhotoLibraryAddUsageDescription": "Agentrix Claw saves share cards to your photo library.",
        "NSPhotoLibraryUsageDescription": "Agentrix Claw reads the photo library to select images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./frontend/public/brand/agentrix-logo.png",
        "backgroundColor": "#000000"
      },
      "package": "app.agentrix.claw",
      "permissions": [
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "agentrix"
            },
            {
              "scheme": "https",
              "host": "agentrix.top"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./frontend/public/brand/agentrix-logo.png"
    },
    "newArchEnabled": true,
    "runtimeVersion": "1.1.0",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "url": "https://u.expo.dev/96a641e0-ce03-45ff-9de7-2cd89c488236"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "ndkVersion": "27.0.12077973"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./frontend/public/brand/agentrix-logo.png",
          "color": "#0B1220",
          "sounds": []
        }
      ],
      "expo-updates",
      "expo-image-picker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Agentrix to use the microphone for realtime voice conversations.",
          "speechRecognitionPermission": "Allow Agentrix to use speech recognition for realtime conversations.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts",
            "com.google.android.as"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Agentrix to access your location for AI context."
        }
      ],
      [
        "react-native-ble-plx",
        {
          "neverForLocation": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "96a641e0-ce03-45ff-9de7-2cd89c488236"
      }
    }
  }
}
