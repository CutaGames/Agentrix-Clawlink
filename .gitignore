# Dependencies
node_modules/
**/node_modules/

# Expo / React Native build outputs (generated by expo prebuild)
# android/ and ios/ ARE committed for reproducible CI builds
# .expo-shared is safe to ignore
.expo/
.expo-shared/

# Build outputs
dist/
build/
builds/
*.apk
*.zip

# Environment / secrets — NEVER commit these
.env
.env.*
*.env
*.pem
*.key

# Logs
*.log
npm-debug.log*

# IDE
.idea/
.vscode/
.cursor/
.copilot-debug/
*.swp
.DS_Store

# Test reports
playwright-report/
test-results/
coverage/

# Next.js build output
.next/
frontend/.next/

# Developer helper scripts (may contain tokens)
*.sh
*.py
*.cmd
scripts/*
!scripts/public-build/
!scripts/public-build/**
!scripts/deploy/
!scripts/deploy/**
!scripts/build/
!scripts/build/**
!scripts/check/
!scripts/check/**
!scripts/test/
!scripts/test/**
!scripts/setup/
!scripts/setup/**
!backend/build.sh
!frontend/start-production.sh

# Build artifacts / temp bundles
*.bundle
*.tgz
*.tar.gz
*.patch
*.sql

# CI / debug logs
ci_logs/
*.txt
!README.md
!frontend/public/robots.txt

# Temp directories
tmp/
.tmp-*
.deploy/
patch_out/
backend/backups/
*.sql.gz

# Gradle
mobile-app/

# Desktop (Tauri) build artifacts
desktop/src-tauri/target/
desktop/node_modules/
desktop/dist/
desktop/*.ps1
desktop/*.png
desktop/*.tar.gz
desktop/src-tauri/keys/agentrix.key

# QA credentials (never ship in production)
**/qa-login.json
